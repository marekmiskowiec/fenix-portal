generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  discordId     String?     @unique
  role          Role        @default(CZLONEK)
  accounts      Account[]
  sessions      Session[]
  dues          Due[]
  payments      Payment[]
  vacations     Vacation[]
  characters    Character[]
  createdAt     DateTime    @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  CZLONEK
  RADA
  ADMINISTRATOR
}

// Weekly due record — created every Monday for each member
model Due {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart  DateTime // Monday 00:00 UTC
  amount     Int      @default(500000)
  onVacation Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, weekStart])
}

// Payment / deposit made by or for a member
model Payment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  note      String?
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())
}

// Vacation request — exempts member from dues for N weeks
model Vacation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart DateTime // First Monday of vacation
  weeks     Int      @default(1)
  approved  Boolean  @default(false)
  reason    String?
  createdAt DateTime @default(now())
}

model Character {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  class     String
  level     Int      @default(1)
  guild     String   @default("Fenix")
  inGrota   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Timer {
  id        String   @id @default(cuid())
  name      String
  map       String
  endsAt    DateTime
  createdBy String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// One record per channel, upserted on each kill
model WitchKill {
  id           String    @id @default(cuid())
  channel      String    @unique
  killedAt     DateTime?
  killedByName String?
  killedById   String?
  updatedAt    DateTime  @updatedAt
}

model BossTimer {
  id           String    @id @default(cuid())
  boss         String
  channel      String
  killedAt     DateTime?
  killedByName String?
  killedById   String?
  updatedAt    DateTime  @updatedAt

  @@unique([boss, channel])
}

model BossKill {
  id        String   @id @default(cuid())
  bossName  String
  map       String
  killedAt  DateTime
  reward    Int?
  note      String?
  createdAt DateTime @default(now())
}

model Payout {
  id          String   @id @default(cuid())
  description String
  amount      Int
  recipient   String
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())
}
